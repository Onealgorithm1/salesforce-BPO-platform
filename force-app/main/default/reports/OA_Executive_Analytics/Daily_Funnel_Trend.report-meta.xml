<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Campaign funnel over time: member counts by status across snapshot dates. Sourced from captured daily snapshots. Campaign-agnostic.</description>
    <format>Matrix</format>
    <groupingsAcross>
        <dateGranularity>Day</dateGranularity>
        <field>Campaign_Funnel_Snapshot__c.Snapshot_Date__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsAcross>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Campaign_Funnel_Snapshot__c.Member_Status__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <name>Daily Funnel Trend</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
    <reportType>OA_Campaign_Funnel_Snapshots</reportType>
    <scope>organization</scope>
    <showDetails>false</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
</Report>
