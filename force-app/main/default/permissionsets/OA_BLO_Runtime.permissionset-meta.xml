    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>OA_LifecycleStates</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>OA_CandidateApprovalService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>OA_LeadCreationService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>OA_BusinessLifecycleService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <objectPermissions>
        <object>OA_Discovered_Organization__c</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>OA_Enrichment_Change_Log__c</object>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>OA_Discovered_Organization__c.Reviewed_Contact_Email__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
