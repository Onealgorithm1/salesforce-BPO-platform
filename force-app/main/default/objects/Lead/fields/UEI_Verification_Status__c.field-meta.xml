<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>UEI_Verification_Status__c</fullName>
    <label>UEI Verification Status</label>
    <description>Governance gate for Tier A automated Lead write-back. Verified = Lead UEI confirmed trusted (SAM.gov origin + spot-check). Only Verified Leads are eligible for automated UEI matching. Default Unverified.</description>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Unverified</fullName>
                <default>true</default>
                <label>Unverified</label>
            </value>
            <value>
                <fullName>Verified</fullName>
                <default>false</default>
                <label>Verified</label>
            </value>
            <value>
                <fullName>Rejected</fullName>
                <default>false</default>
                <label>Rejected</label>
            </value>
        </valueSetDefinition>
    </valueSet>
    <trackTrending>false</trackTrending>
</CustomField>
