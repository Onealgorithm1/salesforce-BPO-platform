<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Token metadata for secure communication preference links. Raw token values are never stored.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <label>OA Communication Preference Token</label>
    <nameField>
        <displayFormat>CPT-{000000}</displayFormat>
        <label>Communication Preference Token Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>OA Communication Preference Tokens</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
