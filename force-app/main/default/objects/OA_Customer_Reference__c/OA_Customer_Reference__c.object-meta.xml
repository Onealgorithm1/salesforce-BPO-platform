        <displayFormat>CUST-{0000}</displayFormat>
        <label>Customer Reference</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>OA Customer References</pluralLabel>
    <searchLayouts></searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
