<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Connector run telemetry for the Lead Enrichment Foundation. One row per connector execution; provenance for enrichment changes.</description>
    <enableActivities>false</enableActivities>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>OA Connector Run</label>
    <nameField>
        <displayFormat>RUN-{00000}</displayFormat>
        <label>OA Connector Run Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>OA Connector Runs</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
