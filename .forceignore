# ============================================================
# ONE ALGORITHM — .forceignore
# Controls what sf project retrieve/deploy includes/excludes
# ============================================================

# ----------------------------------------------------------
# MANAGED PACKAGE NAMESPACES
# These are installed ISV packages — never retrieve or deploy
# ----------------------------------------------------------
CHANNEL_ORDERS__*
sfcma__*
sfLma__*
sfFma__*
KPIapp__*
MHolt__*

# ----------------------------------------------------------
# INTERNAL SALESFORCE INTEGRATION ARTIFACTS
# Platform-managed, not user-deployable
# ----------------------------------------------------------
sfdcInternalInt__*
**/permissionsets/sfdcInternalInt__sfdc_nc_constraints_engine_deploy*
**/permissionsets/sfdcInternalInt__sfdc_activityplatform*

# ----------------------------------------------------------
# EAC / MOBILECONFIG
# Not accessible via Metadata API (confirmed June 2026)
# ----------------------------------------------------------
MobileConfig
EinsteinActivityCaptureSetting

