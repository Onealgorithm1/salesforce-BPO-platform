<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     ONE ALGORITHM — PBO Client Configuration Manifest
     Target directory: clients/pbo/
     Run: sf project retrieve start --manifest manifest/package-pbo.xml \
          --output-dir clients/pbo

     What belongs here: metadata that is specific to One Algorithm's
     own Salesforce org (PBO Edition) and would NOT be deployed to
     any future client org. This includes:

       - ISV/LMA infrastructure (trigger + test class)
       - One Algorithm website (Communities/Site controllers, pages, LWC)
       - OA branding and site assets (static resources)
       - VF components tied to the Communities site template

     If One Algorithm ever deploys a client org, none of this
     metadata ships to that client. It stays in clients/pbo/ only.
     ============================================================ -->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">

  <!-- APEX CLASSES — OA Website (Communities/Site) + ISV infrastructure -->
  <!-- 20 standard Salesforce Communities/Site controllers (platform-generated,         -->
  <!-- never modified from default) + 1 ISV LMA test class = 21 total.                 -->
  <!-- These run the One Algorithm public website and ISV license infrastructure.        -->
  <!-- They are PBO-specific; no generic client org would receive these.                 -->
  <types>
    <members>TestLinkCOACustomerToLMALicense</members>
    <members>ChangePasswordController</members>
    <members>ChangePasswordControllerTest</members>
    <members>CommunitiesLandingController</members>
    <members>CommunitiesLandingControllerTest</members>
    <members>CommunitiesLoginController</members>
    <members>CommunitiesLoginControllerTest</members>
    <members>CommunitiesSelfRegConfirmController</members>
    <members>CommunitiesSelfRegConfirmControllerTest</members>
    <members>CommunitiesSelfRegController</members>
    <members>CommunitiesSelfRegControllerTest</members>
    <members>ForgotPasswordController</members>
    <members>ForgotPasswordControllerTest</members>
    <members>MicrobatchSelfRegController</members>
    <members>MicrobatchSelfRegControllerTest</members>
    <members>MyProfilePageController</members>
    <members>MyProfilePageControllerTest</members>
    <members>SiteLoginController</members>
    <members>SiteLoginControllerTest</members>
    <members>SiteRegisterController</members>
    <members>SiteRegisterControllerTest</members>
    <name>ApexClass</name>
  </types>

  <!-- APEX TRIGGERS — ISV/LMA license linkage -->
  <!-- Ties COA customer records to LMA license records.                                -->
  <!-- Only relevant because OA is an ISV partner with LMA installed.                  -->
  <!-- Client orgs will not have LMA; this trigger cannot be deployed to clients.       -->
  <types>
    <members>linkCOACustomerToLMALicense</members>
    <name>ApexTrigger</name>
  </types>

  <!-- STATIC RESOURCES — One Algorithm branding and site assets -->
  <!-- All 6 static resources are OA website / branding assets.                        -->
  <!-- leaflet: JavaScript mapping library used exclusively by worldMap LWC below.      -->
  <!-- SiteSamples: Salesforce-provided site template samples, PBO site-specific.       -->
  <!-- SNA_kMhXn_...: OA CDN-cached asset (auto-named by Salesforce site builder).     -->
  <types>
    <members>construction</members>
    <members>onealgo</members>
    <members>OnealgorithLogo</members>
    <members>leaflet</members>
    <members>SiteSamples</members>
    <members>SNA_kMhXn_sf_default_cdn_One_Algorithm1</members>
    <name>StaticResource</name>
  </types>

  <!-- LWC — One Algorithm website components -->
  <!-- All 7 LWC bundles are components for the OA public website.                     -->
  <!-- None are generic reusable components; all carry OA branding or website logic.   -->
  <types>
    <members>contactform</members>
    <members>contactFormNew</members>
    <members>worldMap</members>
    <members>customheader</members>
    <members>policy</members>
    <members>serviceAccordion</members>
    <members>oneAlgorithmLanding</members>
    <name>LightningComponentBundle</name>
  </types>

  <!-- VISUALFORCE COMPONENTS — OA Communities site template parts -->
  <!-- SiteHeader, SiteFooter, SiteLogin, SitePoweredBy are platform-generated         -->
  <!-- site template components. They are PBO site-specific.                            -->
  <types>
    <members>SiteFooter</members>
    <members>SiteHeader</members>
    <members>SiteLogin</members>
    <members>SitePoweredBy</members>
    <name>ApexComponent</name>
  </types>

  <!-- VISUALFORCE PAGES — OA Communities site pages (24 total) -->
  <!-- Standard Salesforce site/community page templates, installed when the OA site   -->
  <!-- was created. Paired with Communities/Site Apex controllers above.                -->
  <!-- my_Test: likely a development test page; review for deletion post-retrieval.     -->
  <types>
    <members>AnswersHome</members>
    <members>BandwidthExceeded</members>
    <members>ChangePassword</members>
    <members>CommunitiesLanding</members>
    <members>CommunitiesLogin</members>
    <members>CommunitiesSelfReg</members>
    <members>CommunitiesSelfRegConfirm</members>
    <members>CommunitiesTemplate</members>
    <members>Exception</members>
    <members>FileNotFound</members>
    <members>ForgotPassword</members>
    <members>ForgotPasswordConfirm</members>
    <members>IdeasHome</members>
    <members>InMaintenance</members>
    <members>MicrobatchSelfReg</members>
    <members>my_Test</members>
    <members>MyProfilePage</members>
    <members>SiteLogin</members>
    <members>SiteRegister</members>
    <members>SiteRegisterConfirm</members>
    <members>SiteTemplate</members>
    <members>StdExceptionTemplate</members>
    <members>Unauthorized</members>
    <members>UnderConstruction</members>
    <name>ApexPage</name>
  </types>

  <version>67.0</version>
</Package>
